# Futu API Configuration
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_CONNECTION_TIMEOUT=30

# Data Storage
DATA_DIR=./data
CACHE_DIR=./data/cache
REPORT_DIR=./data/reports
LOG_DIR=./data/logs

# Analysis Parameters
HISTORICAL_DAYS=365
PREDICTION_HORIZON=10
TOP_N_RESULTS=20
MIN_HISTORY_DAYS=50

# Market Filters
MIN_VOLUME=1000000
MIN_TURNOVER=10000000
MIN_PRICE=1.0
MAX_PRICE=10000.0

# Performance
PARALLEL_PROCESSING=true
MAX_WORKERS=4
BATCH_SIZE=50

# Logging
LOG_LEVEL=INFO
LOG_FILE_ROTATION=daily
LOG_MAX_FILES=30